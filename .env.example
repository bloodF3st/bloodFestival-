# Одна строка на переменную: повтор BOT_TOKEN= / ADMINS_TGID= ниже перезапишет значение пустым.
BOT_TOKEN=
ADMINS_TGID=
# Отдельная БД только для token-бота: другое имя базы в конце URL, чем у userbot (НЕ тот же DATABASE_URL что BloodHarvest).
# TOKEN_DATABASE_URL=postgresql://myuser:mysecret@localhost:5432/bloodfestival_token
# Запасной вариант, если TOKEN_DATABASE_URL не задан (в лог будет предупреждение):
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
# Имя сессии в колонке session_name таблиц задач (не путать с сессией userbot)
BF_SESSION_NAME=bloodfestival
# Папка шаблонов .txt (как USER_TEMPLATES_DIR у userbot)
USER_TEMPLATES_DIR=data/user_templates